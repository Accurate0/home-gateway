        {
          "description": "Fires on a scalar sensor reading. `metric` is the reading/object_id name\n(e.g. `soil_moisture`, `temperature`); the flattened comparison is the\nthreshold. The dispatcher fires on the rising edge of the comparison.",
          "type": "object",
          "properties": {
            "metric": {
              "$ref": "#/$defs/SensorMetric"
            },
            "op": {
              "$ref": "#/$defs/CompareOp"
            },
            "sensor": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "environment"
            },
            "value": {
              "type": "number",
              "format": "double"
            }
          },
          "required": [
            "type",
            "sensor",
            "metric",
            "op",
            "value"
          ]
        },
        {
          "description": "Fires on a recurring schedule. `schedule` is a standard 5-field cron\nexpression (e.g. `\"0 20 * * THU\"`), evaluated in local time. Driven by the\n[`crate::actors::cron::CronActor`] producer, which matches by trigger name.",
          "type": "object",
          "properties": {
            "schedule": {
              "$ref": "#/$defs/CronSchedule"
            },
            "type": {
              "type": "string",
              "const": "cron"
            }
          },
          "required": [
            "type",
            "schedule"
          ]
        },
        {
          "description": "Fires at a sun transition (`sunrise`/`sunset`), driven by the\n[`crate::actors::sun::SunActor`] producer.",
          "type": "object",
          "properties": {
            "offset": {
              "type": "string",
              "default": [
                0,
                0
              ]
            },
            "transition": {
              "$ref": "#/$defs/SunTransition"
            },
            "type": {
              "type": "string",
              "const": "sun"
            }
          },
          "required": [
            "type",
            "transition"
          ]
        },
        {
          "description": "Fires when a house mode is entered (`active: true`) or exited\n(`active: false`), driven by `set_mode`.",
          "type": "object",
          "properties": {
            "active": {
              "type": "boolean"
            },
            "mode": {
              "$ref": "#/$defs/Mode"
            },
            "type": {
              "type": "string",
              "const": "mode"
            }
          },
          "required": [
            "type",
            "mode",
            "active"
          ]
        },
        {
          "description": "Fires when a Home Assistant entity changes state, driven by the\n[`crate::actors::home_assistant`] producer. Optionally gate on the entity\nreaching a specific `state`.",
          "type": "object",
          "properties": {
            "entity_id": {
              "type": "string"
            },
            "state": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "type": {
              "type": "string",
              "const": "home_assistant"
            }
          },
          "required": [
            "type",
            "entity_id"
          ]
        },
        {
          "description": "Fires when a tracked Woolworths product drops in price, driven by the\n[`crate::actors::woolworths`] producer. Optionally gate on a specific\n`product_id` and/or a minimum drop amount (in dollars).",
          "type": "object",
          "properties": {
            "min_drop": {
              "type": [
                "number",
                "null"
              ],
