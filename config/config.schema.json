              "default": null
            },
            "product_id": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64",
              "default": null
            },
            "type": {
              "type": "string",
              "const": "woolworths"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "description": "Fires when a poll-transport device reports its battery voltage on\ncheck-in. Optionally gate on a specific `device_id`, device `kind`,\nand/or a `below` voltage threshold for low-battery alerts.",
          "type": "object",
          "properties": {
            "below": {
              "type": [
                "number",
                "null"
              ],
              "format": "double",
              "default": null
            },
            "device_id": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "kind": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "type": {
              "type": "string",
              "const": "device_battery"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
