            "sensor": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "presence"
            }
          },
          "required": [
            "type",
            "sensor",
            "present"
          ]
        },
        {
          "type": "object",
          "properties": {
            "device": {
              "type": "string"
            },
            "open": {
              "type": "boolean"
            },
            "type": {
              "type": "string",
              "const": "door"
            }
