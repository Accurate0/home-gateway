{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawSettings",
  "description": "On-disk shape of the config. Deserialized first, then [`RawSettings::resolve`]\nresolves device aliases / notify targets and unifies sensor keying so the rest\nof the app only ever sees the fully-resolved [`Settings`].",
  "type": "object",
  "properties": {
    "alarm": {
      "$ref": "#/$defs/AlarmSettings"
    },
    "android_app_webhook_secret": {
      "type": "string"
    },
    "api_key": {
      "type": "string"
    },
    "api_keys": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ApiKeySettings"
      }
    },
    "database_url": {
      "type": "string"
    },
    "devices": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RawSensor"
      }
    },
    "fcm_project_id": {
      "type": "string",
      "default": ""
    },
    "fcm_service_account_json": {
      "type": "string",
      "default": ""
    },
    "home_assistant": {
      "$ref": "#/$defs/HomeAssistantSettings"
    },
    "location": {
      "$ref": "#/$defs/LocationSettings"
    },
    "mqtt_password": {
      "type": "string"
    },
    "mqtt_url": {
      "type": "string"
    },
    "mqtt_username": {
      "type": "string"
    },
    "notify_targets": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/NotifySource"
      }
    },
    "oauth": {
      "anyOf": [
        {
          "$ref": "#/$defs/OAuthSettings"
        },
        {
          "type": "null"
        }
      ]
    },
    "s3": {
      "$ref": "#/$defs/S3Settings"
    },
    "trmnl": {
      "$ref": "#/$defs/TrmnlSettings"
    },
    "trmnl_api_key": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "unifi_webhook_secret": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": ""
    },
    "watchdog": {
      "$ref": "#/$defs/WatchdogSettings"
    },
    "woolworths": {
      "$ref": "#/$defs/WoolworthsSettings"
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/RawWorkflow"
        }
      }
    }
  },
  "required": [
    "api_key",
    "database_url",
    "mqtt_url",
    "mqtt_username",
    "mqtt_password",
    "unifi_webhook_secret",
    "android_app_webhook_secret",
    "s3",
    "watchdog",
    "location"
  ],
  "$defs": {
    "AlarmSettings": {
      "type": "object",
      "properties": {
        "offset": {
          "type": "string",
          "default": "5m"
        },
        "poll_interval": {
          "type": "string",
          "default": "1m"
        },
        "workflow": {
          "type": "string",
          "default": "alarm-wakeup"
        }
      }
    },
    "ApiKeySettings": {
      "description": "Declarative API key: config is the source of truth for a key's name + scope.\nSecret material is never here — the admin API mints/regenerates the token and\nstartup reconciles these scopes onto the matching DB row by `name`.",
      "type": "object",
      "properties": {
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "name": {
          "type": "string"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "scopes"
      ]
    },
    "Capability": {
      "type": "string",
      "enum": [
        "brightness",
        "colour_temp",
        "rgb",
        "temperature",
        "humidity",
        "pressure",
        "lux",
        "uv_index"
      ]
    },
    "Combinator": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Condition"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "all"
          ]
        },
        {
          "type": "object",
          "properties": {
            "any": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Condition"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "any"
          ]
        },
        {
          "type": "object",
          "properties": {
            "not": {
              "$ref": "#/$defs/Condition"
            }
          },
          "additionalProperties": false,
          "required": [
            "not"
          ]
        }
      ]
    },
    "CompareOp": {
      "type": "string",
      "enum": [
        "gt",
        "lt",
        "gte",
        "lte",
        "eq"
      ]
    },
    "Condition": {
      "description": "A boolean predicate evaluated against current device/sensor state. Either a\nnested boolean combinator (`all`/`and`, `any`/`or`, `not`) or a leaf test.",
      "anyOf": [
        {
          "$ref": "#/$defs/Combinator"
        },
        {
          "$ref": "#/$defs/LeafCondition"
        }
      ]
    },
    "CronSchedule": {
      "description": "Deserialized straight from a cron string by croner's `serde` feature, so the\nconfig accepts the full readable syntax: day/month aliases (`THU`, `JAN`),\nnicknames (`@weekly`, `@daily`), ranges (`MON-FRI`) and steps (`*/15`).",
      "type": "string"
    },
    "DeviceConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawDoorSettings"
            },
            "kind": {
              "type": "string",
              "const": "door"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawPresenceBlock"
            },
            "kind": {
              "type": "string",
              "const": "presence"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawEnvironmentBlock"
            },
            "kind": {
              "type": "string",
              "const": "environment"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawPlantBlock"
            },
            "kind": {
              "type": "string",
              "const": "plant"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawLightBlock"
            },
            "kind": {
              "type": "string",
              "const": "light"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "control_switch"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawSmartSwitchBlock"
            },
            "kind": {
              "type": "string",
              "const": "smart_switch"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawEinkDisplayBlock"
            },
            "kind": {
              "type": "string",
              "const": "eink_display_firmware"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawTrmnlBlock"
            },
            "kind": {
              "type": "string",
              "const": "trmnl"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/RawRoborockBlock"
            },
            "kind": {
              "type": "string",
              "const": "roborock"
            }
          },
          "required": [
            "kind",
            "config"
          ]
        }
      ]
    },
    "EnableState": {
      "description": "Target enablement for a `set_workflows_enabled` step. `Toggle` flips the\nwhole tagged set together, based on whether any member is currently enabled.",
      "type": "string",
      "enum": [
        "ENABLED",
        "DISABLED",
        "TOGGLE"
      ]
    },
    "EntitySettings": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "latest_state": {
          "type": "boolean",
          "default": true
        },
        "log": {
          "type": "boolean",
          "default": true
        },
        "throttle": {
          "type": "string",
          "default": "0s"
        }
      },
      "required": [
        "id"
      ]
    },
    "EnvMetric": {
      "description": "Which reading of an environment sensor a condition compares against.",
      "type": "string",
      "enum": [
        "temperature",
        "humidity",
        "pressure",
        "lux",
        "uv_index"
      ]
    },
    "HomeAssistantSettings": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntitySettings"
          }
        }
      }
    },
    "LeafCondition": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "device": {
              "type": "string"
            },
            "on": {
              "type": "boolean"
            },
            "type": {
              "type": "string",
              "const": "light"
            }
          },
          "required": [
            "type",
            "device",
            "on"
          ]
        },
        {
          "description": "A scalar comparison: `{ op: gt, value: 30 }`. Flattened into the\n[`Condition::Environment`] variant.",
          "type": "object",
          "properties": {
            "metric": {
              "$ref": "#/$defs/EnvMetric"
            },
            "op": {
              "$ref": "#/$defs/CompareOp"
            },
            "sensor": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "environment"
            },
            "value": {
              "type": "number",
              "format": "double"
            }
          },
          "required": [
            "type",
            "sensor",
            "metric",
            "op",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "present": {
              "type": "boolean"
            },
            "sensor": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "presence"
            }
          },
          "required": [
            "type",
            "sensor",
            "present"
          ]
        },
        {
          "type": "object",
          "properties": {
            "device": {
              "type": "string"
            },
            "open": {
              "type": "boolean"
            },
            "type": {
              "type": "string",
              "const": "door"
            }
          },
          "required": [
            "type",
            "device",
            "open"
          ]
        },
        {
          "type": "object",
          "properties": {
            "after": {
              "type": [
                "string",
                "null"
              ],
              "format": "partial-time",
              "default": null
            },
            "before": {
              "type": [
                "string",
                "null"
              ],
              "format": "partial-time",
              "default": null
            },
            "type": {
              "type": "string",
              "const": "time_of_day"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "is": {
              "$ref": "#/$defs/SunPeriod"
            },
            "offset": {
              "type": "string",
              "default": [
                0,
                0
              ]
            },
            "type": {
              "type": "string",
              "const": "sun"
            }
          },
          "required": [
            "type",
            "is"
          ]
        },
        {
          "type": "object",
          "properties": {
            "active": {
              "type": "boolean"
            },
            "mode": {
              "$ref": "#/$defs/Mode"
            },
            "type": {
              "type": "string",
              "const": "mode"
            }
          },
          "required": [
            "type",
            "mode",
            "active"
          ]
        }
      ]
    },
    "LocationSettings": {
      "type": "object",
      "properties": {
        "latitude": {
          "type": "number",
          "format": "double"
        },
        "longitude": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "latitude",
        "longitude"
      ]
    },
    "Mode": {
      "type": "string",
      "enum": [
        "home",
        "away",
        "vacation",
        "night",
        "guest",
        "party"
      ]
    },
    "NotifyRef": {
      "description": "A reference to a notify destination: either the name of a target declared\nunder `notify_targets:`, or an inline source.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/NotifySource"
        }
      ]
    },
    "NotifySource": {
      "oneOf": [
        {
          "description": "Push notification to all registered HomeGateway Android devices.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "android_app"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
    "OAuthSettings": {
      "description": "OAuth (OIDC) settings. Access tokens are JWTs validated locally against the\nprovider's JWKS — no client secret is needed. A caller's scopes are derived\nfrom their group memberships (the `groups_claim`) via `group_scopes`.",
      "type": "object",
      "properties": {
        "audience": {
          "type": "string"
        },
        "group_scopes": {
          "description": "group SPN -> granted scope strings (`domain:resource:action`).",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "groups_claim": {
          "type": "string",
          "default": "groups"
        },
        "issuer": {
          "type": "string"
        },
        "jwks_url": {
          "type": "string"
        },
        "userinfo_url": {
          "type": "string"
        }
      },
      "required": [
        "issuer",
        "jwks_url",
        "userinfo_url",
        "audience",
        "group_scopes"
      ]
    },
    "RawDeviceWatchdog": {
      "type": "object",
      "properties": {
        "notify": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NotifyRef"
          }
        },
        "timeout": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "RawDoorSettings": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "notify": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NotifyRef"
          }
        }
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "state": {
              "type": "string",
              "const": "armed"
            },
            "timeout": {
              "type": "string"
            }
          },
          "required": [
            "state",
            "timeout"
          ]
        },
        {
          "type": "object",
          "properties": {
            "state": {
              "type": "string",
              "const": "unarmed"
            }
          },
          "required": [
            "state"
          ]
        }
      ],
      "required": [
        "name",
        "id"
      ]
    },
    "RawEinkDisplayBlock": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "refresh": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "s3_key": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "settle": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "sleep": {
          "anyOf": [
            {
              "$ref": "#/$defs/RawSleepWindow"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name"
      ]
    },
    "RawEnvironmentBlock": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "object",
          "properties": {
            "humidity": {
              "type": "string"
            },
            "lux": {
              "type": "string"
            },
            "pressure": {
              "type": "string"
            },
            "temperature": {
              "type": "string"
            },
            "uv_index": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "id"
      ]
    },
    "RawLightBlock": {
      "type": "object",
      "properties": {
        "entity": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "RawPlantBlock": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "default": [
            "soil_moisture"
          ],
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    },
    "RawPresenceBlock": {
      "type": "object",
      "properties": {
        "motion_entity": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string",
          "default": ""
        }
      }
    },
    "RawRoborockBlock": {
      "type": "object",
      "properties": {
        "battery_entity": {
          "type": "string"
        },
        "control_entity": {
          "type": "string"
        },
        "dock_service": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "room_entity": {
          "type": "string"
        },
        "status_entity": {
          "type": "string"
        },
        "stop_service": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "status_entity",
        "battery_entity",
        "room_entity",
        "control_entity",
        "stop_service",
        "dock_service"
      ]
    },
    "RawSensor": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Capability"
          }
        },
        "id": {
          "type": "string"
        },
        "kinds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DeviceConfig"
          }
        },
        "room": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "transport": {
          "$ref": "#/$defs/Transport"
        },
        "watchdog": {
          "anyOf": [
            {
              "$ref": "#/$defs/RawDeviceWatchdog"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "transport",
        "address",
        "kinds"
      ]
    },
    "RawSleepWindow": {
      "type": "object",
      "properties": {
        "end": {
          "type": "string"
        },
        "start": {
          "type": "string"
        }
      },
      "required": [
        "start",
        "end"
      ]
    },
    "RawSmartSwitchBlock": {
      "type": "object",
      "properties": {
        "as": {
          "anyOf": [
            {
              "$ref": "#/$defs/SwitchRole"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "RawTrmnlBlock": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "RawWorkflow": {
      "type": "object",
      "properties": {
        "cooldown": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "delay": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "dry_run": {
          "type": "boolean",
          "default": false
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "group": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "on": {
          "anyOf": [
            {
              "$ref": "#/$defs/TriggerMatcher"
            },
            {
              "type": "null"
            }
          ]
        },
        "run": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Step"
          }
        },
        "slug": {
          "type": "string",
          "default": ""
        },
        "tags": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "when": {
          "anyOf": [
            {
              "$ref": "#/$defs/Condition"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "run"
      ]
    },
    "S3Settings": {
      "description": "S3 / object-storage config. Credentials are taken from the standard AWS\nenvironment, never from this file. `endpoint` is only set for\nS3-compatible stores (MinIO/R2/…); omit it for plain AWS S3.",
      "type": "object",
      "properties": {
        "bucket": {
          "type": "string"
        },
        "endpoint": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "region": {
          "type": "string"
        }
      },
      "required": [
        "bucket",
        "region"
      ]
    },
    "SensorMetric": {
      "description": "A named scalar sensor reading. Known metrics are typed; anything else (an\nesphome object_id we don't model) falls back to [`SensorMetric::Other`] so\nproducers and config stay honest without an exhaustive list.",
      "type": "string"
    },
