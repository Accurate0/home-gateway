{
  "name": "home-gateway-frontends",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:eink": "pnpm --filter eink-display-web build",
    "dev:web": "pnpm --filter web dev",
    "dev:eink": "pnpm --filter eink-display-web dev",
    "lint": "pnpm -r lint"
  }
}
