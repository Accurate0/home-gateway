{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>anurag/k8s//platform-services/renovate/presets/default"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["open-feature"],
      "matchManagers": ["cargo"],
      "enabled": false
    },
    {
      "matchPackageNames": ["recharts"],
      "matchManagers": ["npm"],
      "enabled": false
    },
    {
      "matchPackageNames": ["sqlx"],
      "matchManagers": ["cargo"],
      "enabled": false
    },
    {
      "matchFileNames": ["eink-display-web/**"],
      "groupName": "eink-display-web",
      "postUpgradeTasks": {
        "commands": [
          "sh -c 'cd eink-display-web && pnpm install --no-frozen-lockfile && pnpm relay'"
        ],
        "fileFilters": ["eink-display-web/src/**/__generated__/*.graphql.ts"],
        "executionMode": "branch"
      }
    },
    {
      "matchFileNames": ["eink-display-firmware/**"],
      "enabled": false
    },
    {
      "matchFileNames": ["HomeGateway/**"],
      "groupName": "HomeGateway"
    },
    {
      "matchFileNames": [
        "Cargo.toml",
        "Cargo.lock",
        "src/**",
        "Dockerfile",
        "Dockerfile.postgres",
        "docker-compose.yaml"
      ],
      "groupName": "home-gateway"
    }
  ]
}
