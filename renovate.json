{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>anurag/k8s//platform-services/renovate/presets/pin-github-actions",
    "local>anurag/k8s//platform-services/renovate/presets/npm-min-release-age"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["open-feature"],
      "matchManagers": ["cargo"],
      "enabled": false
    },
    {
      "matchPackageNames": ["recharts"],
      "matchManagers": ["npm"],
      "enabled": false
    },
    {
      "matchFileNames": ["eink-display-web/**"],
      "groupName": "eink-display-web"
    },
    {
      "matchFileNames": ["eink-display-firmware/**"],
      "enabled": false
    },
    {
      "matchFileNames": ["selfbot/**"],
      "groupName": "selfbot"
    },
    {
      "matchFileNames": ["HomeGateway/**"],
      "groupName": "HomeGateway"
    },
    {
      "matchFileNames": [
        "Cargo.toml",
        "Cargo.lock",
        "src/**",
        "Dockerfile",
        "Dockerfile.postgres",
        "docker-compose.yaml"
      ],
      "groupName": "home-gateway"
    }
  ]
}
