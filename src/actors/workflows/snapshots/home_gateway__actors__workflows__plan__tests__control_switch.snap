---
source: src/actors/workflows/plan.rs
expression: out
---
# Control Switch on  (on: switch(control_switch) action=on)
  light: light(table_lamp_bedroom) -> On

# Control Switch off  (on: switch(control_switch) action=off)
  light: light(table_lamp_bedroom) -> Off

# Control Switch brightness up  (on: switch(control_switch) action=brightness_move_up)
  light: light(table_lamp_bedroom) -> IncreaseBrightness { value: 75, on_off: false }

# Control Switch brightness down  (on: switch(control_switch) action=brightness_move_down)
  light: light(table_lamp_bedroom) -> DecreaseBrightness { value: 75, on_off: false }

# Control Switch brightness stop  (on: switch(control_switch) action=brightness_stop)
  light: light(table_lamp_bedroom) -> StopBrightness

# Control Switch colour temp up  (on: switch(control_switch) action=arrow_right_hold)
  light: light(table_lamp_bedroom) -> IncreaseColourTemperature { value: 120 }

# Control Switch colour temp down  (on: switch(control_switch) action=arrow_left_hold)
  light: light(table_lamp_bedroom) -> DecreaseColourTemperature { value: 120 }

# Control Switch colour temp stop left  (on: switch(control_switch) action=arrow_left_release)
  light: light(table_lamp_bedroom) -> StopColourTemperature

# Control Switch colour temp stop right  (on: switch(control_switch) action=arrow_right_release)
  light: light(table_lamp_bedroom) -> StopColourTemperature

# Control Switch set brightness low  (on: switch(control_switch) action=arrow_left_click)
  light: light(table_lamp_bedroom) -> SetBrightness { value: 50 }

# Control Switch set brightness high  (on: switch(control_switch) action=arrow_right_click)
  light: light(table_lamp_bedroom) -> SetBrightness { value: 254 }
